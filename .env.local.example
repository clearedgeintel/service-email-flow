# ============================================================
# ServiceFlow — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Gmail API (OAuth2) ---
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_SEND_AS=serviceconnect@yourdomain.com

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Twilio ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Admin Auth ---
ADMIN_PASSWORD=admin
SESSION_SECRET=random-32-char-string-here

# --- Business Defaults (overridden by DB settings) ---
BUSINESS_NAME=ProFix Electric & Plumbing
BUSINESS_PHONE=(555) 123-4567
TECH_EMAIL=tech@yourcompany.com
TECH_PHONE=+15559876543
OWNER_EMAIL=owner@yourcompany.com
CALCOM_EMERGENCY_URL=https://cal.com/profix/emergency
CALCOM_SERVICE_URL=https://cal.com/profix/service-call
CALCOM_ESTIMATE_URL=https://cal.com/profix/free-estimate
CONFIDENCE_THRESHOLD=0.70
